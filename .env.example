OPENAI_MODEL=qwen3.5-plus
# OPENAI_MODEL=deepseek-reasoner
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
# OPENAI_API_KEY=
MODEL_ID=qwen3.5-plus
# MODEL_ID=deepseek-reasoner
# EMBEDDING_MODEL=text-embedding-v4

# ---------------- Database ----------------
# 支持: sqlite / mysql / postgresql
DB_TYPE=sqlite

# sqlite 配置（DB_TYPE=sqlite 时生效）
SQLITE_PATH=data/assistant.db

# mysql / postgresql 通用配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=app
DB_USERNAME=
DB_PASSWORD=

# 连接池配置
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# 证书连接模式（mysql / postgresql）
# 开启后将不使用 DB_USERNAME / DB_PASSWORD，改为证书参数连接
DB_USE_CERT_AUTH=false
DB_SSL_CA=
DB_SSL_CERT=
DB_SSL_KEY=

# postgresql 证书模式可配置 sslmode（建议 verify-full）
DB_SSL_MODE=verify-full